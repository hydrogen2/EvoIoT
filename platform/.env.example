# EvoIoT Platform Environment Variables
# Copy to .env and configure for your deployment

# =============================================================================
# Database
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# =============================================================================
# Zitadel Identity Provider
# =============================================================================
ZITADEL_MASTERKEY=a-very-secret-master-key-32-chars!
ZITADEL_ADMIN_PASSWORD=Admin123!

# =============================================================================
# PostgREST API
# =============================================================================
# Generate with: openssl rand -base64 32
PGRST_JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars

# =============================================================================
# LiteLLM - LLM Provider Keys
# =============================================================================
# Uncomment and set the providers you want to use
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# AZURE_API_KEY=...
# AZURE_API_BASE=https://your-resource.openai.azure.com

LITELLM_MASTER_KEY=sk-dev-master-key

# =============================================================================
# External APIs (for context data sources)
# =============================================================================
# OPENWEATHERMAP_API_KEY=...

# =============================================================================
# Grafana
# =============================================================================
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
